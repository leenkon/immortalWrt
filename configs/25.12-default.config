# ImmortalWrt x86-64 虚拟机主路由 | 25.12
# 特性：USB网卡/4G网卡支持 + 4G拨号+ nftables FullCone

# 设备配置
CONFIG_TARGET_DEVICE_x86_64_DEVICE_generic=y
CONFIG_MODULES=y
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_BOARD="x86"
CONFIG_TARGET_SUBTARGET="64"
CONFIG_TARGET_ARCH_PACKAGES="x86_64"
CONFIG_LINUX_6_6=y
CONFIG_CPU_TYPE="x86-64"
# 编译优化
CONFIG_IPV6=y
CONFIG_USE_SSTRIP=y
CONFIG_AUTOREMOVE=y
# 镜像与分区
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=960
# 基础系统
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_grub2-bios-setup=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_procd-ujail=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_urandom-seed=y
# 主路由常用功能
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts_aliyun=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-vlan=y
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_udpxy=y
# LuCI 界面
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_LUCI_DEFAULT_THEME="argon"
CONFIG_LUCI_LANG_zh_Hans=y
# 有线/虚拟化网卡驱动
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-vmxnet3=y
CONFIG_PACKAGE_kmod-r8169=y

# ========== 4G/USB 拨号、串口、调制解调器全套依赖 ==========
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-comgt=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_usb-modeswitch-data=y
# 4G协议支持（QMI/MBIM）
CONFIG_PACKAGE_kmod-qmi-wwan=y
CONFIG_PACKAGE_kmod-mbim=y
CONFIG_PACKAGE_kmod-cdc-ncm=y
CONFIG_PACKAGE_kmod-cdc-wdm=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-mbim=y
# 4G工具
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_qmi-utils=y
# USB 基础驱动（USB网卡、4G卡）
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
# USB无线网卡驱动（随身WiFi）
CONFIG_PACKAGE_kmod-rtl8812au=y
CONFIG_PACKAGE_kmod-rtl8821au=y
CONFIG_PACKAGE_kmod-rtl88x2bu=y
CONFIG_PACKAGE_kmod-mt7601u=y
# 文件系统 & 字符编码（兼容USB/4G卡分区）
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
# 网络核心/NAT/连接跟踪
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
# nftables 原生 FullCone NAT（适配 Firewall4）
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_nftables-fullcone=y
# 禁用调试/无用包
CONFIG_PACKAGE_kselftests-bpf=n
CONFIG_PACKAGE_perf=n
CONFIG_PACKAGE_objdump=n
CONFIG_PACKAGE_kmod-bpf-test=n
CONFIG_PACKAGE_zabbix=n
CONFIG_PACKAGE_python-ubus=n
CONFIG_PACKAGE_libnetsnmp-ssl=n
CONFIG_PACKAGE_libelf=n
# 无线模块（虚拟机无WiFi，关闭缩减体积）
CONFIG_PACKAGE_hostapd=n
CONFIG_PACKAGE_wpad-basic=n