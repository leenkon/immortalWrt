# 旁路由定位：纯去广告 + 代理服务
# 主路由承担：拨号 / DHCP / NAT / 防火墙 / 多线 / 4G
# 排序规范：编译架构 -> 镜像分区 -> 基础系统 -> 驱动网络 -> LuCI界面 -> 功能插件
# == 编译架构与优化参数 ==
CONFIG_MODULES=y
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_BOARD="x86"
CONFIG_TARGET_SUBTARGET="64"
CONFIG_TARGET_ARCH_PACKAGES="x86_64"
CONFIG_LINUX_6_6=y
CONFIG_CPU_TYPE="x86-64"
CONFIG_TARGET_DEVICE_x86_64_DEVICE_generic=y
CONFIG_ALL_NONSHARED=y
CONFIG_IPV6=y
CONFIG_USE_SSTRIP=y
CONFIG_AUTOREMOVE=y
# == 镜像、分区、打包配置 ==
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=960
# == 核心基础系统组件 ==
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_procd-ujail=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_urandom-seed=y
# == 驱动、文件系统、网络模块 ==
# 网卡驱动（虚拟+物理全覆盖）
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-vmxnet3=y
CONFIG_PACKAGE_kmod-r8169=y
# 文件系统
CONFIG_PACKAGE_kmod-fs-ext4=y
# 基础网络连接跟踪
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y
# == LuCI 界面、主题、中文环境 ==
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_LUCI_DEFAULT_THEME="argon"
CONFIG_LUCI_LANG_zh_Hans=y
# == 全局禁用冗余/调试包 ==
CONFIG_PACKAGE_kselftests-bpf=n
CONFIG_PACKAGE_perf=n
CONFIG_PACKAGE_objdump=n
CONFIG_PACKAGE_kmod-bpf-test=n
CONFIG_PACKAGE_zabbix=n
CONFIG_PACKAGE_python-ubus=n
CONFIG_PACKAGE_libnetsnmp-ssl=n
CONFIG_PACKAGE_libelf=n
# == AdGuard Home 全屋去广告 ==
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_kmod-ipset=y
# == OpenClash 代理服务 ==
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_clash-meta=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_ruby=y
CONFIG_PACKAGE_ruby-yaml=y
CONFIG_PACKAGE_unzip=y